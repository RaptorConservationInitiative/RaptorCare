#!/bin/bash
### Läuft, aber ohne UI!
# RaptorCare Installation Script
# Installs all required packages, PostgreSQL, virtualenv, and initializes the database.
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

set -euo pipefail

PYTHON_BIN="python3.12"

TARGET_DIR="/opt/raptorcare"
ENV_FILE="$TARGET_DIR/.env"
EXAMPLE_ENV="$TARGET_DIR/.env.example"
VENV_DIR="$TARGET_DIR/venv"

function echo_step() {
    echo -e "\n🔧 $1"
}

if [[ $EUID -ne 0 ]]; then
    echo "❌ Please run this script as root: sudo bash scripts/install_server.sh"
    exit 1
fi

echo "🦅 RaptorCare Installation (Production Mode)"
echo "===================================="

# RaptorCare directories
# =========================

UPLOAD_DIR="/var/lib/raptorcare/uploads"

echo "📁 Creating upload directory..."
sudo mkdir -p "$UPLOAD_DIR"
sudo chown -R raptorcare:raptorcare /var/lib/raptorcare
sudo chmod -R 750 /var/lib/raptorcare

# -------------------------
# SYSTEM DEPENDENCIES
# -------------------------
echo_step "Installing system dependencies..."
apt-get update
apt-get install -y \
    software-properties-common \
    git curl wget \
    python3.12 python3.12-venv python3.12-dev \
    postgresql libpq-dev \
    nodejs npm \
    rsync

# -------------------------
# MOVE PROJECT TO /opt
# -------------------------
echo_step "Deploying project to /opt/raptorcare..."

mkdir -p "$TARGET_DIR"

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

rsync -a --exclude 'venv' --exclude '.git' "$REPO_ROOT/" "$TARGET_DIR/"

REPO_ROOT="$TARGET_DIR"
cd "$REPO_ROOT"

chown -R root:root "$TARGET_DIR"

# -------------------------
# VIRTUAL ENV
# -------------------------
echo_step "Preparing Python virtual environment..."

if [ ! -d "$VENV_DIR" ]; then
    $PYTHON_BIN -m venv "$VENV_DIR"
fi

source "$VENV_DIR/bin/activate"

echo_step "Ensuring pip availability..."

if ! python -m pip --version >/dev/null 2>&1; then
    $PYTHON_BIN -m ensurepip --upgrade || true
fi

if ! python -m pip --version >/dev/null 2>&1; then
    curl -sS https://bootstrap.pypa.io/get-pip.py | $PYTHON_BIN
fi

echo_step "Upgrading pip tooling..."
python -m pip install --upgrade pip setuptools wheel

# -------------------------
# PYTORCH (CUDA 11.8)
# -------------------------
echo_step "Installing PyTorch (CUDA 11.8)..."

python -m pip install \
  torch==2.2.2+cu118 torchvision==0.17.2+cu118 torchaudio==2.2.2+cu118 \
  --index-url https://download.pytorch.org/whl/cu118

echo "✅ PyTorch installed"

# -------------------------
# PYTHON REQUIREMENTS
# -------------------------
echo_step "Installing Python dependencies..."
python -m pip install -r "$REPO_ROOT/requirements.txt"

# -------------------------
# UI BUILD
# -------------------------
echo_step "Building UI components..."

if [ -d "$REPO_ROOT/server_ui" ]; then
  cd "$REPO_ROOT/server_ui"
  npm install
  npm run build
fi

if [ -d "$REPO_ROOT/station_ui" ]; then
  cd "$REPO_ROOT/station_ui"
  npm install
  npm run build
fi

cd "$REPO_ROOT"

# -------------------------
# POSTGRESQL
# -------------------------
echo_step "Starting PostgreSQL..."
systemctl enable postgresql --now

echo_step "Creating database and user..."

sudo -u postgres psql <<'SQL'
DO $$
BEGIN
    IF NOT EXISTS (SELECT FROM pg_roles WHERE rolname = 'raptorcare') THEN
        CREATE ROLE raptorcare LOGIN PASSWORD 'raptorcare_password';
    END IF;
END$$;

DO $$
BEGIN
    IF NOT EXISTS (SELECT FROM pg_database WHERE datname = 'raptorcare_db') THEN
        CREATE DATABASE raptorcare_db OWNER raptorcare;
    END IF;
END$$;
SQL

# -------------------------
# ENV FILE
# -------------------------
echo_step "Setting up .env..."

if [ ! -f "$ENV_FILE" ]; then
    cp "$EXAMPLE_ENV" "$ENV_FILE"
fi

# -------------------------
# DB INIT
# -------------------------
echo_step "Initializing database..."
bash "$REPO_ROOT/scripts/init_db.sh"

# -------------------------
# OLLAMA
# -------------------------
echo_step "Installing Ollama..."

if ! command -v ollama >/dev/null 2>&1; then
    curl -fsSL https://ollama.ai/install.sh | sh
fi

OLLAMA_BIN="$(command -v ollama || true)"

# -------------------------
# SYSTEM USER
# -------------------------
echo_step "Creating system user..."

if ! id -u raptorcare >/dev/null 2>&1; then
    useradd --system --no-create-home --shell /usr/sbin/nologin raptorcare
fi

chown -R raptorcare:raptorcare "$REPO_ROOT"

# -------------------------
# SYSTEMD SERVICE
# -------------------------
echo_step "Installing systemd service..."

echo "⚙️ Creating systemd service..."

sudo tee /etc/systemd/system/raptorcare.service > /dev/null <<EOF
[Unit]
Description=RaptorCare Server
After=network.target

[Service]
Type=simple
User=raptorcare
WorkingDirectory=/opt/raptorcare
Environment="PYTHONUNBUFFERED=1"

ExecStart=/opt/raptorcare/venv/bin/uvicorn server.main:app \
  --host 0.0.0.0 \
  --port 8000

Restart=on-failure
RestartSec=5
TimeoutStartSec=500

# Important for file writes
ReadWritePaths=/var/lib/raptorcare

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
#systemctl enable --now raptorcare.service

systemctl enable raptorcare.service

echo "🚀 Starting service..."
if ! systemctl start raptorcare.service; then
    echo "⚠️ Service failed to start (see logs):"
    systemctl status raptorcare.service --no-pager || true
    journalctl -xeu raptorcare.service --no-pager || true
fi

# -------------------------
# OLLAMA SERVICE
# -------------------------
if [[ -n "$OLLAMA_BIN" ]]; then

    echo_step "Installing Ollama service..."

    if ! id -u ollama >/dev/null 2>&1; then
        useradd --system --no-create-home --shell /usr/sbin/nologin ollama
    fi

    mkdir -p /var/lib/ollama/models
    chown -R ollama:ollama /var/lib/ollama || true

    cat > /etc/systemd/system/ollama.service <<EOF
[Unit]
Description=Ollama LLM Server
After=network.target

[Service]
Type=simple
User=ollama
Environment="PATH=$PATH"
ExecStart=$OLLAMA_BIN serve
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable --now ollama.service
fi

# -------------------------
# DONE
# -------------------------
echo ""
echo "✅ INSTALLATION COMPLETE"
echo "========================"
echo "Server: systemctl status raptorcare.service"
echo "Path: $REPO_ROOT"
echo ""

# -------------------------
# FINAL CHECK
# -------------------------
echo_step "Healthcheck"

sleep 3
curl -s http://localhost:8000/health || echo "⚠️ API not ready yet"

echo ""
echo "✅ INSTALL COMPLETE"