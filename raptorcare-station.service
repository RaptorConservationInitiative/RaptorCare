[Unit]
Description=RaptorCare Station FastAPI Server
After=network.target

[Service]
Type=simple
User=raptorcare-station
WorkingDirectory=/opt/raptorcare-station
Environment="PATH=/opt/raptorcare-station/venv/bin"
ExecStart=/opt/raptorcare-station/venv/bin/uvicorn station.app:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
